# ============================================================
# bashrc_local.sh — 用户本地覆盖（不进入版本控制）
# ============================================================
# 复制此文件为 bashrc_local.sh 并修改。
# 该文件会被 bashrc_base.sh 自动加载。

# --- 覆盖实际用户名（SLURM 作业名等默认标识） ---
# 默认由 bashrc_base.sh 从目录结构自动推断。
# 如果自动检测不准确，可在此强制指定：
# export ACTUAL_USER="your_name"

# --- 示例：覆盖 micromamba 根目录 ---
# export MAMBA_ROOT_PREFIX=/share/home/team_xxx/.conda

# --- 示例：覆盖 uv 相关目录 ---
# export UV_TOOL_DIR="/another/path/.uv/tools"
# export UV_TOOL_BIN_DIR="/another/path/.uv/bin"

# --- 示例：添加自定义 PATH ---
# export PATH="/my/custom/bin:$PATH"

# --- 示例：OpenCode 配置 ---
# OpenCode 是一个开源的 AI 编码代理（opencode.ai）。
# 将二进制放入 00_static_tools/opencode 后，可通过以下变量控制路径。
#
# 核心环境变量（参考 https://opencode.ai/docs/zh-cn/config/）：
#
# 1) 配置文件路径（全局默认 ~/.config/opencode/opencode.json）
#    多人共用账号时，改为指向 HPC_SU_HOME 下以隔离：
# export OPENCODE_CONFIG="$HPC_SU_HOME/.opencode/opencode.json"
#
# 2) 配置目录（存放 agents/commands/plugins/themes/skills/tools 等子目录）
#    等价于标准 .opencode 目录，改为用户独立路径：
# export OPENCODE_CONFIG_DIR="$HPC_SU_HOME/.opencode"
#
# 3) 内联配置（运行时覆盖，优先级最高，适合临时调试）：
# export OPENCODE_CONFIG_CONTENT='{"model":"anthropic/claude-sonnet-4-5","autoupdate":false}'
#
# 4) 各 Provider 的 API Key（按需设置，优先使用各 Provider 标准环境变量）：
# export ANTHROPIC_API_KEY="sk-xxx"
# export OPENAI_API_KEY="sk-xxx"

# --- 示例：添加自定义别名 ---
# alias my_train="python /path/to/train.py"
